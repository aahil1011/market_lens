# Firebase
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
VITE_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Backend proxy
VITE_BACKEND_ORIGIN=http://127.0.0.1:8000

# Optional production API origin for the deployed frontend.
# Leave empty if Firebase Hosting rewrites /api to Cloud Run.
VITE_API_BASE_URL=

# Python backend APIs
FINNHUB_API_KEY=your_finnhub_api_key
GNEWS_API_KEY=your_gnews_api_key
HF_API_TOKEN=your_huggingface_token
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile

# Backend host/port
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Frontend origins allowed to call the backend directly in production
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
